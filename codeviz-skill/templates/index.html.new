<script>
// ============================================================
// 状态变化动效演示 - 模拟一个任务从 pending → in-progress → done
// 吴八哥接后端时，WebSocket 收到 tasks.updated 消息后调用此逻辑
// ============================================================

function simulateStatusChange() {
  // 找到 T006（未开始），3秒后变成进行中，再3秒变成完成
  const task = document.querySelectorAll('.task')[4]; // T006
  if (!task) return;

  setTimeout(() => {
    task.classList.remove('pending');
    task.classList.add('in-progress', 'pulse');
    task.querySelector('.task-status-icon').textContent = '◐';
    setTimeout(() => task.classList.remove('pulse'), 600);
  }, 3000);

  setTimeout(() => {
    task.classList.remove('in-progress', 'pulse');
    task.classList.add('done', 'pulse');
    task.querySelector('.task-status-icon').textContent = '✓';
    setTimeout(() => task.classList.remove('pulse'), 600);
  }, 6000);
}

// 页面加载后 1 秒开始演示
setTimeout(simulateStatusChange, 1000);

// ============================================================
// 数据接口说明（给吴八哥看）
// ============================================================
// 每个任务卡片需要以下字段：
// {
//   id: "T001",              // 任务 ID
//   name: "初始化项目脚手架",  // 任务名
//   status: "done",          // pending | in-progress | done | error
//   parallel: false,         // 是否可并行（显示 P 标签）
//   description: "...",      // 任务描述
//   files: ["a.ts","b.ts"],  // 关联文件
//   fileStats: { existing: 2, total: 2 },  // 文件存在情况（决定 .exists 样式）
//   depends: ["T001"],       // 依赖任务 ID 数组
//   relatedCommits: [        // 关联 commit（进行中/报错才显示）
//     { hash: "a3f2c1d", message: "feat: ..." }
//   ],
//   lastCommitDate: "2026-07-03",
//   errorMessage: "TypeError: ...",  // 报错时显示
//   completedDate: "2026-07-01"      // 完成时显示
// }
//
// Phase 需要：
// { id, name, tasks: [...], stats: { done, total } }
//
// 全局统计：
// { total, done, inProgress, pending, error }
// → 用于左侧进度环和统计网格
// ============================================================
</script>

</body>
</html>
